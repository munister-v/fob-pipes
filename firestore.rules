rules_version = '2';

// Firestore security rules for the Ф.О.Б site.
//
// Model:
//  • site/* (catalog, categories, content) — publicly readable; writes only
//    by the allowlisted Firebase Auth admin.
//  • quotes/* — anyone may CREATE a request (public quote form); only an
//    allowlisted admin may read, update status or delete.
//
// Firebase Auth Email/Password is enabled. Admin login:
//   tilandiya@gmail.com

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "tilandiya@gmail.com";
    }

    match /site/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quotes/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

